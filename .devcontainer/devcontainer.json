{
    "name": "Automated Posting System",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "forwardPorts": [
        6080
    ],
    "portsAttributes": {
        "6080": {
            "label": "Virtual Desktop (noVNC)",
            "onAutoForward": "openPreview"
        }
    },
    "postCreateCommand": "pip3 install -r requirements.txt && playwright install --with-deps chromium",
    "remoteUser": "vscode"
}